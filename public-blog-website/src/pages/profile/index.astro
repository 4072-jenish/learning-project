---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { SITE_TITLE } from "../../consts";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Profile | ${SITE_TITLE}`} description="User profile" />

		<style>
			main {
				max-width: 1100px;
				margin: 0 auto;
				padding: 4rem 1.5rem;
			}

			.profile-hero {
				padding: 2rem;
				border-radius: 28px;
				background: rgb(var(--black));
				color: white;
				margin-bottom: 2rem;
			}

			.avatar {
				width: 80px;
				height: 80px;
				border-radius: 50%;
				background: white;
				color: rgb(var(--black));
				display: flex;
				align-items: center;
				justify-content: center;
				font-size: 2rem;
				font-weight: 900;
				margin-bottom: 1rem;
			}

			h1 {
				margin: 0;
				font-size: clamp(2rem, 5vw, 4rem);
				letter-spacing: -0.06em;
			}

			.email {
				color: rgba(255, 255, 255, 0.75);
				margin-top: 0.4rem;
			}

			.stats {
				display: grid;
				grid-template-columns: repeat(4, 1fr);
				gap: 1rem;
				margin-top: 2rem;
			}

			.stat-card {
				padding: 1.2rem;
				border-radius: 18px;
				background: white;
				color: rgb(var(--black));
			}

			.stat-card strong {
				display: block;
				font-size: 2rem;
			}

			.stat-card span {
				color: rgb(var(--gray));
			}

			.actions {
				margin-top: 2rem;
				display: flex;
				gap: 1rem;
				flex-wrap: wrap;
			}

			button, a.btn {
				border: 0;
				border-radius: 12px;
				padding: 0.9rem 1.2rem;
				font-weight: 800;
				cursor: pointer;
				text-decoration: none;
			}

			.logout {
				background: #ef4444;
				color: white;
			}

			.btn {
				background: rgb(var(--accent));
				color: white;
			}

			.section {
				margin-top: 2rem;
				padding: 1.5rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 22px;
				background: white;
			}

			.loading {
				color: rgb(var(--gray));
			}

			@media (max-width: 700px) {
				.stats {
					grid-template-columns: repeat(2, 1fr);
				}
			}
            .userName {
                color: #fff;
            }
		</style>
	</head>

	<body>
		<Header />

		<main>
			<section class="profile-hero">
				<div class="avatar" id="avatar">U</div>

				<h1 id="userName" class="userName">Loading...</h1>
				<p class="email" id="userEmail">Loading...</p>

				<div class="stats">
					<div class="stat-card">
						<strong id="blogsCount">0</strong>
						<span>Blogs</span>
					</div>

					<div class="stat-card">
						<strong id="likesCount">0</strong>
						<span>Likes</span>
					</div>

					<div class="stat-card">
						<strong id="commentsCount">0</strong>
						<span>Comments</span>
					</div>

					<div class="stat-card">
						<strong id="sharesCount">0</strong>
						<span>Shares</span>
					</div>
				</div>

				<div class="actions">
					<a href="/blog" class="btn">Explore Blogs</a>
					<button id="logoutBtn" class="logout">Logout</button>
				</div>
			</section>

			<section class="section">
				<h2>Account Details</h2>
				<p><strong>Role:</strong> <span id="userRole">-</span></p>
				<p><strong>Status:</strong> <span id="userStatus">-</span></p>
			</section>
		</main>

		<Footer />
        <script src="/src/scripts/profile-action.ts" type="module"></script>
	</body>
</html>