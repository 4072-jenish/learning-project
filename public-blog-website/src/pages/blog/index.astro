---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const res = await fetch(`${import.meta.env.PUBLIC_API_BASE_URL}blog/`);
const data = await res.json();

const posts = data.blogs || [];
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Blogs | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />

		<style>
			main {
				max-width: 1100px;
				margin: 0 auto;
				padding: 4rem 1.5rem;
			}

			.page-hero {
				margin-bottom: 3rem;
				text-align: center;
			}

			.badge {
				display: inline-block;
				margin-bottom: 1rem;
				padding: 0.45rem 0.8rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 999px;
				color: rgb(var(--accent));
				font-size: 0.9rem;
				font-weight: 700;
			}

			h1 {
				margin: 0;
				font-size: clamp(2.4rem, 6vw, 4.5rem);
				line-height: 0.95;
				letter-spacing: -0.07em;
			}

			.page-hero p {
				max-width: 650px;
				margin: 1.25rem auto 0;
				color: rgb(var(--gray));
				font-size: 1.1rem;
			}

			.blog-grid {
				display: grid;
				grid-template-columns: repeat(3, 1fr);
				gap: 1.25rem;
				list-style: none;
				padding: 0;
				margin: 0;
			}

			.blog-card {
				border: 1px solid rgb(var(--gray-light));
				border-radius: 22px;
				overflow: hidden;
				background: white;
				transition: 0.2s ease;
			}

			.blog-card:hover {
				transform: translateY(-4px);
				box-shadow: var(--box-shadow);
			}

			.blog-card a {
				display: block;
				color: inherit;
				text-decoration: none;
			}

			.image-wrap {
				height: 210px;
				background:
					radial-gradient(circle at top left, rgba(var(--accent), 0.35), transparent 35%),
					linear-gradient(135deg, rgb(var(--gray-light)), white);
			}

			.image-wrap img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
			}

			.card-content {
				padding: 1.25rem;
			}

			.date {
				margin: 0 0 0.7rem;
				color: rgb(var(--gray));
				font-size: 0.9rem;
			}

			.title {
				margin: 0;
				font-size: 1.25rem;
				line-height: 1.15;
				letter-spacing: -0.03em;
				color: rgb(var(--black));
			}

			.excerpt {
				margin: 0.8rem 0 0;
				color: rgb(var(--gray));
				font-size: 0.95rem;
				line-height: 1.6;
			}

			.read-more {
				display: inline-block;
				margin-top: 1rem;
				color: rgb(var(--accent));
				font-weight: 700;
			}

			.empty-state {
				padding: 3rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 24px;
				text-align: center;
				background: white;
			}

			.empty-state p {
				color: rgb(var(--gray));
			}

			@media (max-width: 900px) {
				.blog-grid {
					grid-template-columns: repeat(2, 1fr);
				}
			}

			@media (max-width: 640px) {
				main {
					padding: 3rem 1rem;
				}

				.blog-grid {
					grid-template-columns: 1fr;
				}
			}
		</style>
	</head>

	<body>
		<Header />

		<main>
			<section class="page-hero">
				<span class="badge">Latest Blogs</span>
				<h1>Fresh stories, ideas, and insights.</h1>
				<p>
					Browse approved articles from our writers and discover something worth reading today.
				</p>
			</section>

			<section>
				{
					posts.length > 0 ? (
						<ul class="blog-grid">
							{posts.map((post: any) => (
								<li class="blog-card">
									<a href={`/blog/${post.id}/`}>
										<div class="image-wrap">
											{post.imageUrl && (
												<img
													src={post.imageUrl}
													alt={post.title}
													loading="lazy"
												/>
											)}
										</div>

										<div class="card-content">
											<p class="date">
												<FormattedDate date={new Date(post.createdAt)} />
											</p>

											<h2 class="title">{post.title}</h2>

											<p class="excerpt">
												{post.content?.slice(0, 120)}...
											</p>

											<span class="read-more">Read article →</span>
										</div>
									</a>
								</li>
							))}
						</ul>
					) : (
						<div class="empty-state">
							<h2>No blogs published yet.</h2>
							<p>Approved blogs will appear here once writers publish them.</p>
						</div>
					)
				}
			</section>
		</main>

		<Footer />
	</body>
</html>