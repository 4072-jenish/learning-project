---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { SITE_TITLE } from "../../consts";
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Login | ${SITE_TITLE}`} description="Login to your account" />

		<style>
			main {
				min-height: 75vh;
				display: flex;
				align-items: center;
				justify-content: center;
				padding: 3rem 1rem;
			}

			.auth-card {
				width: 100%;
				max-width: 430px;
				padding: 2rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 24px;
				background: white;
				box-shadow: var(--box-shadow);
			}

			h1 {
				margin: 0 0 0.5rem;
				font-size: 2.4rem;
				letter-spacing: -0.06em;
			}

			p {
				color: rgb(var(--gray));
				margin-bottom: 1.5rem;
			}

			label {
				display: block;
				margin-bottom: 0.4rem;
				font-weight: 700;
			}

			input {
				width: 100%;
				padding: 0.9rem 1rem;
				margin-bottom: 1rem;
				border: 1px solid rgb(var(--gray-light));
				border-radius: 12px;
				font-size: 1rem;
			}

			button {
				width: 100%;
				padding: 0.95rem;
				border: 0;
				border-radius: 12px;
				background: rgb(var(--accent));
				color: white;
				font-weight: 800;
				cursor: pointer;
			}

			.link {
				margin-top: 1rem;
				text-align: center;
			}
		</style>
	</head>

	<body>
		<Header />

		<main>
			<form class="auth-card" id="loginForm">
				<h1>Welcome back</h1>
				<p>Login to like, comment, and share blogs.</p>

				<label>Email</label>
				<input id="email" type="email" required placeholder="Enter email" />

				<label>Password</label>
				<input id="password" type="password" required placeholder="Enter password" />

				<button type="submit">Login</button>

				<div class="link">
					Don't have an account? <a href="/auth/signup">Sign up</a>
				</div>
			</form>
		</main>

		<Footer />

		<script>
			const form = document.getElementById("loginForm");

			form?.addEventListener("submit", async (e) => {
				e.preventDefault();

				const email = document.getElementById("email") as HTMLInputElement;
				const password = document.getElementById("password") as HTMLInputElement;

				try {
					const res = await fetch(`${import.meta.env.PUBLIC_API_BASE_URL}auth/login`, {
						method: "POST",
						headers: {
							"Content-Type": "application/json",
						},
						body: JSON.stringify({
							email: email.value,
							password: password.value,
						}),
					});

					const data = await res.json();

					if (!res.ok) {
						alert(data.message || "Login failed");
						return;
					}

					localStorage.setItem("token", data.token);
					localStorage.setItem("user", JSON.stringify(data.user));

					alert("Login successful");
					window.location.href = "/blog";
				} catch (error) {
					console.error(error);
					alert("Something went wrong");
				}
			});
		</script>
	</body>
</html>